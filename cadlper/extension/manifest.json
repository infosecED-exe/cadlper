{
  "manifest_version": 3,
  "name": "Cadlper",
  "description": "Cadlper DLP Agent",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "DLP Agent",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
